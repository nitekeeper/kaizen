# Plugin-internal state
.ai/
experiment/

# Process artifacts — belong in Memex/Notion, not git (kaizen#51)
# Cycle minutes, bridge-smoke reports, design specs, plans are write-once
# history with no runtime consumer. Memex (`memex:run capture`) is the
# canonical store; Notion Claude HQ → Decisions is the human-facing mirror.
docs/kaizen/
docs/plans/
docs/design/
docs/design.md
docs/plan.md

# Release dist bundles — body gitignored, manifest tracked
# (the build path is dist/v<X.Y.Z>/; manifest.json is committed so version
# drift can be detected via diff. Bundle bodies are rebuilt by
# `scripts.release` and attached to GitHub Releases.)
dist/v*/
!dist/v*/manifest.json

# Python
__pycache__/
*.pyc
.pytest_cache/

# Worktrees
.worktrees/

# Editors / IDEs
.idea/                 # JetBrains (PhpStorm, WebStorm, IntelliJ, PyCharm, GoLand, etc.)
.vscode/               # Visual Studio Code
.vs/                   # Visual Studio
.fleet/                # JetBrains Fleet
*.sublime-project
*.sublime-workspace
*.code-workspace
.history/              # VS Code Local History extension
*.iml                  # JetBrains module files

# Editor swap/backup/lock files
*.swp
*.swo
*.swn
*~
.#*
\#*\#
.netrwhist

# OS metadata
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
.claude/worktrees/
